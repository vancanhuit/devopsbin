# Local TLS material generated by the certs:* tasks (mkcert). The PEMs are
# host-specific (issued by an ephemeral or per-developer CA) and must never be
# committed; the directories are kept via tls/dev/.gitkeep and tls/test/.gitkeep.
tls/dev/*.pem
tls/test/*.pem
