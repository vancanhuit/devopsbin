#!/usr/bin/env bash
# [MISE] description="Build the multi-platform container image with buildx (OCI export or registry push)."
#
# By default the image is exported as an OCI archive to dist/ (PR validation,
# no registry needed). Pass --push to build and push the manifest to a registry
# (main/push). Designed to run identically locally and in CI.
#
# [USAGE] flag "--push" help="Push the manifest to the registry instead of exporting an OCI archive"
# [USAGE] flag "--platforms <platforms>" help="Comma-separated target platforms" default="linux/amd64,linux/arm64"
# [USAGE] flag "--image <image>" help="Image reference without tag" default="devopsbin"
# [USAGE] flag "--tag <tag>" help="Image tag (repeatable to push several tags at once)" var=#true default="latest"
# [USAGE] flag "--dry-run" help="Print the expanded buildx command without running it"

set -euo pipefail
IFS=$'\n\t'

# shellcheck source-path=SCRIPTDIR
# shellcheck source=../../lib/build.sh
source "${MISE_PROJECT_ROOT:?}/mise/lib/build.sh"

# VERSION, COMMIT and BUILD_TIME come from the global [env] section in mise.toml
# and are forwarded to the image build as build args.
platforms="${usage_platforms:?}"
image="${usage_image:?}"

# --tag is variadic: usage_tag holds a shell-escaped, space-separated list.
# Expand it into repeated `--tag image:tag` arguments for buildx.
eval "tags=(${usage_tag:-latest})"
tag_args=()
# shellcheck disable=SC2154 # `tags` is populated by the eval above.
for t in "${tags[@]}"; do
    tag_args+=(--tag "$image:$t")
done

# A multi-platform build cannot load into the local docker image store, so the
# two modes are push (publish the manifest) or OCI archive export (validate the
# build without a registry, e.g. on pull requests).
if [ "${usage_push:-false}" = "true" ]; then
    output="--push"
else
    output="--output=type=oci,dest=dist/devopsbin.oci.tar"
fi

# Persisted BuildKit layer cache, shared with the Compose build and (in CI)
# round-tripped through actions/cache. Requires a docker-container builder (the
# default on dev hosts, provisioned in CI).
#
# Cache is written to a fresh directory and atomically swapped in after a
# successful build (the "move-cache" pattern). Reusing one directory for both
# cache-from and cache-to lets BuildKit accumulate orphaned blobs from previous
# build graphs, which is what made .cache/buildx grow without bound and blow the
# 10 GiB Actions cache quota. mode=max is intentional: the work worth caching
# lives in the discarded `builder` stage, so mode=min would export almost
# nothing useful.
cache_dir=".cache/buildx"
cache_new=".cache/buildx-new"
cmd=(
    docker buildx build
    --platform "$platforms"
    --build-arg "VERSION=${VERSION:?}"
    --build-arg "COMMIT=${COMMIT:?}"
    --build-arg "BUILD_TIME=${BUILD_TIME:?}"
    "--cache-from=type=local,src=$cache_dir"
    "--cache-to=type=local,dest=$cache_new,mode=max"
    "${tag_args[@]}"
    "$output"
    .
)

if [ "${usage_dry_run:-false}" = "true" ]; then
    print_cmd "${cmd[@]}"
    exit 0
fi

[ "$output" = "--push" ] || mkdir -p dist
"${cmd[@]}"

# Swap the freshly written cache in, discarding the previous generation so the
# directory holds only the current build's reachable records and cannot grow
# unbounded across builds.
if [ -d "$cache_new" ]; then
    rm -rf "$cache_dir"
    mv "$cache_new" "$cache_dir"
fi
