#!/usr/bin/env bash
# [MISE] description="Generate ephemeral TLS certificates for the smoke:tls tests into tls/test."
# [MISE] tools={mkcert="1.4.4"}
#
# [USAGE] flag "--force" help="Regenerate the certificates even if they already exist"
#
# Generates the leaf trio (devopsbin.pem, devopsbin-key.pem, rootCA.pem) for the
# smoke TLS stack into tls/test, using a throwaway CA that never touches any
# system trust store -- the smoke probes verify against tls/test/rootCA.pem.
# This is what `compose:tls:test:up` (driven by `smoke:tls`) depends on, kept
# separate from the local-dev certs in tls/dev so the disposable CI certs never
# mix with browser-trusted ones.
#
# Idempotent: existing certs are left as-is (pass --force to regenerate).

set -euo pipefail
IFS=$'\n\t'

# shellcheck source-path=SCRIPTDIR
# shellcheck source=../../lib/certs.sh
source "${MISE_PROJECT_ROOT:?}/mise/lib/certs.sh"

gen_ephemeral_certs "${MISE_PROJECT_ROOT}/tls/test" "${usage_force:-false}"
